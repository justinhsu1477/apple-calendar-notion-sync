# Apple ID 帳號（你的 iCloud 信箱）
APPLE_ID=your_apple_id@icloud.com

# App-Specific Password（從 appleid.apple.com 產生）
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Notion Integration Token（從 https://www.notion.so/my-integrations 建立）
NOTION_TOKEN=secret_xxxxxxxx

# Notion Database ID
NOTION_DATABASE_ID=64275e54-7fcc-4bb1-8f8a-509b0f4d3c36

# 同步天數範圍（往前和往後各幾天）
SYNC_DAYS_BACK=7
SYNC_DAYS_FORWARD=30
